{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context-broker": {
      "type": "remote",
      "url": "https://<your-broker-host>/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:CONTEXT_BROKER_TOKEN}"
      }
    }
  },
  "tools": {
    "context-broker_*": false,
    "read": false,
    "edit": false,
    "grep": false,
    "list": false
  },
  "agent": {
    "orchestrator": {
      "tools": {
        "context-broker_kb_search": true,
        "read": true,
        "list": true,
        "grep": true
      }
    },
    "implementation": {
      "tools": {
        "context-broker_kb_search": true,
        "read": true,
        "grep": true,
        "edit": true
      }
    },
    "test_layer": {
      "tools": {
        "context-broker_kb_search": true,
        "read": true,
        "grep": true
      }
    },
    "code_reviewer": {
      "tools": {
        "context-broker_kb_search": true
      }
    },
    "delivery_planner": {
      "tools": {
        "context-broker_kb_search": true
      }
    },
    "pr_planner": {
      "tools": {
        "context-broker_kb_search": true
      }
    },
    "adr_writer": {
      "tools": {
        "context-broker_kb_search": true,
        "read": true,
        "grep": true
      }
    },
    "bug_reviewer": {
      "tools": {
        "context-broker_kb_search": true,
        "read": true,
        "grep": true
      }
    },
    "infra_code": {
      "tools": {
        "context-broker_kb_search": true,
        "read": true,
        "grep": true,
        "edit": true
      }
    },
    "quality_reviewer": {
      "tools": {
        "context-broker_kb_search": true,
        "read": true,
        "grep": true
      }
    },
    "security_reviewer": {
      "tools": {
        "context-broker_kb_search": true,
        "read": true,
        "grep": true
      }
    },
    "test_coverage_reviewer": {
      "tools": {
        "context-broker_kb_search": true,
        "read": true,
        "grep": true
      }
    }
  }
}
