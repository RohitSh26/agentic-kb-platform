# Knowledge Registry connection. kb-builder owns the schema: alembic
# migrations and all build-plane writes go through this URL.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_kb

# Integration tests only.
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_kb_test

# Azure OpenAI / Azure AI Search are reached through injected clients
# (ModelClient, SearchClient) using managed identity — no keys belong here.
