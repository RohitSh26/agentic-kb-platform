# Knowledge Registry connection (read + retrieval_event writes; never DDL).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_kb

# Entra ID bearer-token verification (JWKS-based; no secrets).
MCP_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
MCP_ENTRA_AUDIENCE=api://agentic-kb-context-broker

# Integration tests only: a database already migrated by kb-builder
# (run `make migrate-test-db` from the repo root first).
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_kb_test
