# review-panel draft engine — identifiers and references only, never secret values.
# Copy to the repo-root .env (scripts/run_review_panel_local.sh sources it).

# Optional READ-ONLY GitHub token (private repos / rate limits). The service
# holds no write credential (ADR-0031) — publication is the developer's.
#GITHUB_TOKEN=

# ModelClient shim (mirrors scripts/kb_agent.py). Needed only when computing a
# new draft — fetching a stored draft works without LLM credentials.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
#LLM_API_KEY=
#LLM_BASE_URL=

# Postgres for the LangGraph checkpointer + draft store (dedicated
# review_panel schema). Unset => in-memory fallback (no durability).
#REVIEW_PANEL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic_kb

# Canonical agents/ directory (defaults to ../../agents relative to the service).
#REVIEW_PANEL_AGENTS_DIR=

# Optional kb_search over MCP streamable HTTP.
#REVIEW_PANEL_MCP_URL=
#REVIEW_PANEL_MCP_TOKEN=

# LangSmith tracing, env-gated. The test suite passes with neither set.
#LANGSMITH_TRACING=true
#LANGSMITH_API_KEY=
#LANGSMITH_PROJECT=review-panel
